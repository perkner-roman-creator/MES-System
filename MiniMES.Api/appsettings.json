{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=minimes.db"
  },
  "JwtSettings": {
    "SecretKey": "mini-mes-super-secret-jwt-key-for-authentication-12345",
    "Issuer": "MiniMES.Api",
    "Audience": "MiniMES.Client",
    "ExpirationMinutes": 1440
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "IpWhitelist": [],
    "EndpointWhitelist": ["/swagger", "/health"],
    "ClientWhitelist": [],
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 100
      },
      {
        "Endpoint": "*/api/auth/*",
        "Period": "1m",
        "Limit": 30
      },
      {
        "Endpoint": "*/api/workorders/*",
        "Period": "1m",
        "Limit": 50
      }
    ]
  },
  "IpRateLimitPolicies": {
    "IpRules": []
  }
}

